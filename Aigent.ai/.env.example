# Aigent.ai Environment Variables
# Copy this to .env.local and fill in your credentials

# === Google Gemini AI ===
GEMINI_API_KEY=your-gemini-api-key-here

# === Payment Gateways ===
# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=live  # or sandbox for testing

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# === Email (Resend) ===
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=your-email@example.com

# === Database (Firebase) ===
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}  # or use separate variables
FIREBASE_PROJECT_ID=your-firebase-project-id

# === Deployment ===
VERCEL_TOKEN=your-vercel-token  # for automated deployments
GITHUB_TOKEN=your-github-token  # for GitHub integration

# === Security ===
JWT_SECRET=your-jwt-secret-key
COOKIE_SECRET=your-cookie-secret-key

# === Feature Flags ===
ENABLE_PAYPAL=true
ENABLE_RAZORPAY=true
ENABLE_INTERNATIONAL_PAYMENTS=true

# === Server Configuration ===
PORT=3000
NODE_ENV=production
SERVER_URL=https://your-domain.com