    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.13.0",
    "framer-motion": "^12.38.0",
    "js-zip": "^1.0.1",
    "lucide-react": "^0.468.0",
